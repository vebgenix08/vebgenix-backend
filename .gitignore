# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Turbo local task cache (pure perf cache — safe to delete anytime)
.turbo/

# CDK synthesis output
cdk.out/

# TypeScript build artifacts (generated from .ts source — never commit)
# Applies to aws-infrastructure/lib/**/*.js, *.d.ts, *.js.map
aws-infrastructure/**/*.js
aws-infrastructure/**/*.js.map
aws-infrastructure/**/*.d.ts
# Exclude CDK bin entrypoint check files that some tools expect tracked
!aws-infrastructure/bin/*.ts
!aws-infrastructure/lib/**/*.ts
!aws-infrastructure/config/**/*.ts

# Compiled package outputs (built by tsc, consumed by Lambda bundler)
packages/*/dist/
apps/*/dist/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

.config/
.env
.env.*
!.env.example

# Claude Code local data (worktrees, session files, etc.)
.claude/

postman/reports/
postman/newman-results*.txt
