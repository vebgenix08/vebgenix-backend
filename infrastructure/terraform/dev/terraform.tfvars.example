# =============================================================================
# Dev environment — terraform.tfvars.example
# Copy to terraform.tfvars and fill in values. NEVER commit terraform.tfvars.
# =============================================================================

# AWS Configuration
aws_region     = "ap-south-1"
aws_account_id = "278035644568"

# Neon PostgreSQL
# Get your API key from: https://console.neon.tech/app/settings/api-keys
neon_api_key = "your-neon-api-key-here"

# Get from Neon project → Connection Details → Connection string
# Format: postgresql://user:password@ep-xxx.ap-south-1.aws.neon.tech/dbname?sslmode=require
neon_database_url = "postgresql://neondb_owner:password@ep-xxx.ap-south-1.aws.neon.tech/vebgenix_dev?sslmode=require"

# Frontend URL (used for CORS and Cognito callback URLs)
# Use localhost for dev
frontend_url = "http://localhost:3000"

# Lambda prod alias version
# Set to "1" initially; update after first deployment
prod_lambda_version = "1"

# Alert email (optional for dev)
# Leave empty to skip SNS email subscription
alert_email = ""
# alert_email = "dev-alerts@your-company.com"
