generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Enums
enum UserRole {
  ADMIN
  ACCOUNTANT
  STAFF
  TEACHER
  STUDENT
  PARENT
}

enum PersonaRole {
  SUPER_ADMIN
  TENANT_ADMIN
  STAFF
  STUDENT
  PARENT
}

enum StaffType {
  PRINCIPAL
  HOD
  TEACHER
  ACCOUNTANT
  CLERK
  OTHER
}

enum CampusType {
  SCHOOL
  PU
  DEGREE
}

enum CampusScope {
  SCHOOL
  PU
  ALL
}

enum EnquiryStatus {
  NEW
  CONTACTED
  CONVERTED
  CLOSED
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  INTERVIEW_SCHEDULED
  APPROVED
  REJECTED
  MIGRATED
}

enum Gender {
  Male
  Female
  Other
}

enum DocumentType {
  AADHAR
  MARKS_CARD
  TC
}

enum ReviewDecision {
  RECOMMEND
  NOT_RECOMMEND
  HOLD
}

enum StudentStatus {
  ACTIVE
  ALUMNI
  WITHDRAWN
  SUSPENDED
}

enum AuthStatus {
  ACTIVE
  DISABLED
}

enum MembershipStatus {
  INVITED
  ACTIVE
  DISABLED
}

enum ResetTokenPurpose {
  INVITE_SET_PASSWORD
  FORGOT_PASSWORD
}

enum GlobalRole {
  PLATFORM_SUPER_ADMIN
  PLATFORM_SUPPORT
}

enum MembershipRole {
  ORG_OWNER
  ORG_ADMIN
  TEACHER
  STUDENT
  PARENT
  STAFF
  ACCOUNTANT
}

enum RelationshipType {
  SELF
  CHILD
  WARD
  SPOUSE
  OTHER
}

enum PublishedResultFileType {
  PDF
  EXCEL
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PARTIALLY_PAID
  PAID
  VOID
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CARD
  CHEQUE
  UPI
  ONLINE
}

enum AdjustmentType {
  DISCOUNT
  SCHOLARSHIP
  REFUND
  WRITE_OFF
  MANUAL
}

enum TemplateType {
  ADMISSION_FORM
  FEE_STRUCTURE
  DOC_CHECKLIST
  COMMUNICATION
}

// Models

model Profile {
  id                String       @id @default(uuid()) @db.Uuid
  tenantId          String       @map("tenant_id") @db.Uuid
  email             String?
  fullName          String?      @map("full_name")
  
  // Deprecated Role Fields - Use TenantMembership + RoleDefinition instead
  role              UserRole?    
  personaRole       PersonaRole? @map("persona_role")
  staffType         StaffType?   @map("staff_type")
  
  campusScope       CampusScope? @map("campus_scope")
  allCampusesAccess Boolean      @default(false) @map("all_campuses_access")
  isActive          Boolean      @default(true) @map("is_active")
  lastLoginAt       DateTime?    @map("last_login_at") @db.Timestamptz
  avatarUrl         String?      @map("avatar_url")
  avatarKey         String?      @map("avatar_key")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  tenant             Tenant                @relation(fields: [tenantId], references: [id])
  employee           Employee?
  campusAccess       UserCampusAccess[]
  enquiries          Enquiry[]             @relation("AssignedTo")
  applicationReviews ApplicationReview[]
  verifiedDocuments  ApplicationDocument[]
  
  // Deprecated Permission Model
  profilePermissions ProfilePermission[]   @relation("ProfileToPermissions")
  grantedPermissions ProfilePermission[]   @relation("GrantedByProfile")

  // Auth Relations
  linkedAuthUsers       UserProfileLink[]
  membershipPrimary     TenantMembership[]     @relation("MembershipPrimaryProfile")
  uploadedResultBatches PublishedResultBatch[] @relation("ResultBatchUploader")

  @@index([email])
  @@map("profiles")
}

model RoleDefinition {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String
  description String?
  isSystem    Boolean  @default(false) @map("is_system") // e.g. Primary Owner
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  permissions RolePermission[]
  members     MemberRole[]

  @@unique([tenantId, name])
  @@map("role_definitions")
}

model RolePermission {
  id             String         @id @default(uuid()) @db.Uuid
  roleId         String         @map("role_id") @db.Uuid
  permissionKey  String         @map("permission_key") // e.g. "admissions.view"
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz

  role           RoleDefinition @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionKey])
  @@map("role_permissions")
}

model MemberRole {
  id           String           @id @default(uuid()) @db.Uuid
  membershipId String           @map("membership_id") @db.Uuid
  roleId       String           @map("role_id") @db.Uuid
  assignedAt   DateTime         @default(now()) @map("assigned_at") @db.Timestamptz

  membership   TenantMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  role         RoleDefinition   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([membershipId, roleId])
  @@map("member_roles")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  details    Json?
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  tenantId   String   @map("tenant_id") @db.Uuid

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId, createdAt])
  @@index([action])
  @@map("audit_logs")
}

model Enquiry {
  id             String        @id @default(uuid()) @db.Uuid
  tenantId       String        @map("tenant_id") @db.Uuid
  fullName       String        @map("full_name")
  email          String?
  phone          String
  studentDob     DateTime?     @map("student_dob") @db.Date
  gradeApplied   String        @map("grade_applied")
  previousSchool String?       @map("previous_school")
  parentName     String?       @map("parent_name")
  status         EnquiryStatus @default(NEW)
  assignedToId   String?       @map("assigned_to") @db.Uuid
  notes          String?
  academicYear   String?       @map("academic_year")
  source         String?
  priority       String?
  customFields   Json?         @map("custom_fields")
  campusScope    CampusScope   @map("campus_scope")
  campusId       String        @map("campus_id") @db.Uuid
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  campus       Campus        @relation(fields: [campusId], references: [id])
  assignedTo   Profile?      @relation("AssignedTo", fields: [assignedToId], references: [id])
  applications Application[]

  @@index([email])
  @@index([phone])
  @@index([tenantId])
  @@index([tenantId, campusId, createdAt])
  @@map("enquiries")
}

model Application {
  id        String  @id @default(uuid()) @db.Uuid
  tenantId  String  @map("tenant_id") @db.Uuid
  enquiryId String? @map("enquiry_id") @db.Uuid
  applicantId String? @map("applicant_id") @db.Uuid

  // Applicant Details
  fullName    String   @map("full_name")
  dob         DateTime @db.Date
  gender      Gender?
  nationality String?
  bloodGroup  String?  @map("blood_group")

  // Contact Details
  email   String?
  phone   String
  address Json?

  // Parent Details
  fatherName  String? @map("father_name")
  fatherPhone String? @map("father_phone")
  motherName  String? @map("mother_name")
  motherPhone String? @map("mother_phone")

  // Academic Details
  gradeApplyingFor        String   @map("grade_applying_for")
  academicYear            String   @map("academic_year") // Deprecated string
  academicYearId          String?  @map("academic_year_id") @db.Uuid
  stream                  String?
  previousSchool          String?  @map("previous_school")
  previousGradePercentage Decimal? @map("previous_grade_percentage") @db.Decimal(5, 2)

  // Status
  status            ApplicationStatus @default(DRAFT)
  stageHistory      Json?             @default("[]") @map("stage_history")
  approvedAt        DateTime?         @map("approved_at") @db.Timestamptz
  applicationNumber String?           @map("application_number")
  customFields      Json?             @map("custom_fields")

  campusScope CampusScope @map("campus_scope")
  campusId    String      @map("campus_id") @db.Uuid
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  tenant          Tenant                @relation(fields: [tenantId], references: [id])
  campus          Campus                @relation(fields: [campusId], references: [id])
  enquiry         Enquiry?              @relation(fields: [enquiryId], references: [id])
  student         Student?
  documents       ApplicationDocument[]
  reviews         ApplicationReview[]
  academicYearRef AcademicYear?         @relation(fields: [academicYearId], references: [id])
  applicant       Applicant?            @relation(fields: [applicantId], references: [id])
  offer           AdmissionOffer?

  @@unique([tenantId, campusId, applicationNumber])
  @@index([status])
  @@index([tenantId])
  @@index([tenantId, campusId, status])
  @@index([tenantId, campusId, createdAt, id])
  @@map("applications")
}

model ApplicationDocument {
  id            String       @id @default(uuid()) @db.Uuid
  applicationId String       @map("application_id") @db.Uuid
  documentType  DocumentType @map("document_type")
  fileUrl       String       @map("file_url")
  isVerified    Boolean      @default(false) @map("is_verified")
  verifiedById  String?      @map("verified_by") @db.Uuid
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  verifiedBy  Profile?    @relation(fields: [verifiedById], references: [id])

  @@map("application_documents")
}

model ApplicationReview {
  id            String          @id @default(uuid()) @db.Uuid
  applicationId String          @map("application_id") @db.Uuid
  reviewerId    String?         @map("reviewer_id") @db.Uuid
  comments      String?
  decision      ReviewDecision?
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  reviewer    Profile?    @relation(fields: [reviewerId], references: [id])

  @@map("application_reviews")
}

model Student {
  id               String  @id @default(uuid()) @db.Uuid
  tenantId         String  @map("tenant_id") @db.Uuid
  applicationId    String  @unique @map("application_id") @db.Uuid
  
  // Deprecated Auth Link
  authUserId       String? @unique @map("auth_user_id") @db.Uuid
  portalAuthUserId String? @unique @map("portal_auth_user_id") @db.Uuid 

  // Unique Identifiers
  registrationNumber String  @map("reg_no")
  admissionNumber    String? @map("admission_number")

  // Personal Info
  fullName    String    @map("full_name")
  email       String?   @map("student_email")
  parentEmail String?   @map("parent_email")
  parentPhone String?   @map("parent_phone")
  dob         DateTime? @db.Date

  // Academic Placement
  currentGrade   String  @map("current_grade")
  currentSection String? @map("current_section")
  stream         String?

  // System
  campusType CampusType @map("campus_type")
  campusId   String     @map("campus_id") @db.Uuid

  status         StudentStatus @default(ACTIVE)
  enrollmentDate DateTime?     @default(now()) @map("enrollment_date") @db.Date

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  campus      Campus      @relation(fields: [campusId], references: [id])
  application Application @relation(fields: [applicationId], references: [id])
  
  // New Auth Link
  authLink       StudentAuthLink?
  feeAssignments StudentFeeAssignment[]
  invoices       Invoice[]
  payments       Payment[]
  receipts       Receipt[]
  adjustments    Adjustment[]

  @@unique([tenantId, campusId, registrationNumber])
  @@index([registrationNumber])
  @@index([tenantId])
  @@index([tenantId, campusId, status])
  @@index([tenantId, campusId, enrollmentDate(sort: Desc)])
  @@index([tenantId, campusId, createdAt, id])
  @@map("students")
}

model StudentAuthLink {
  id         String   @id @default(uuid()) @db.Uuid
  studentId  String   @unique @map("student_id") @db.Uuid
  authUserId String   @unique @map("auth_user_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  authUser   AuthUser @relation(fields: [authUserId], references: [id], onDelete: Cascade)

  @@map("student_auth_links")
}

model Tenant {
  id                 String   @id @default(uuid()) @db.Uuid
  name               String
  slug               String?  @unique
  isActive           Boolean  @default(true) @map("is_active")
  onboardingComplete Boolean  @default(false) @map("onboarding_complete")
  logoUrl            String?  @map("logo_url")
  logoKey            String?  @map("logo_key")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  profiles           Profile[]
  employees          Employee[]
  campuses           Campus[]
  userCampusAccess   UserCampusAccess[]
  enquiries          Enquiry[]
  applications       Application[]
  students           Student[]
  features           TenantFeature[]
  AuditLog           AuditLog[]
  profilePermissions ProfilePermission[]
  memberships        TenantMembership[]
  roleDefinitions    RoleDefinition[]
  
  // New
  academicYears        AcademicYear[]
  programs             Program[]
  templates            Template[]
  applicants           Applicant[]
  feeHeads             FeeHead[]
  feeStructures        FeeStructure[]
  publishedResultBatches PublishedResultBatch[]
  invoices             Invoice[]
  invoiceLines         InvoiceLine[]
  payments             Payment[]
  receipts             Receipt[]
  adjustments          Adjustment[]

  @@map("tenants")
}

model TenantFeature {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  featureKey String   @map("feature_key")
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, featureKey])
  @@map("tenant_features")
}

model PlatformAuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  at         DateTime @default(now()) @db.Timestamptz
  actorId    String   @map("actor_id") @db.Uuid
  actorEmail String?  @map("actor_email")
  action     String
  category   String?
  severity   String   @default("INFO")
  targetType String   @map("target_type")
  targetId   String?  @map("target_id") @db.Uuid
  targetName String?  @map("target_name")
  meta       Json?
  ipAddress  String?  @map("ip_address")

  @@index([at(sort: Desc), id(sort: Desc)])
  @@index([actorId])
  @@index([targetType])
  @@index([category])
  @@index([severity])
  @@map("platform_audit_logs")
}

model Campus {
  id         String     @id @default(uuid()) @db.Uuid
  tenantId   String     @map("tenant_id") @db.Uuid
  name       String
  campusType CampusType @map("campus_type")
  isActive   Boolean    @default(true) @map("is_active")
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  tenant                 Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userCampusAccess       UserCampusAccess[]
  enquiries              Enquiry[]
  applications           Application[]
  students               Student[]
  sections               Section[]
  publishedResultBatches PublishedResultBatch[]
  invoices               Invoice[]
  payments               Payment[]
  receipts               Receipt[]
  adjustments            Adjustment[]

  @@unique([tenantId, name])
  @@map("campuses")
}

model Employee {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  profileId    String    @unique @map("profile_id") @db.Uuid
  employeeCode String?   @map("employee_code")
  phone        String?
  designation  String?
  department   String?
  joinedOn     DateTime? @map("joined_on") @db.Date
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  profile Profile @relation(fields: [profileId], references: [id])

  @@unique([tenantId, employeeCode])
  @@index([tenantId])
  @@map("employees")
}

model UserCampusAccess {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  profileId String   @map("profile_id") @db.Uuid
  campusId  String   @map("campus_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  profile Profile @relation(fields: [profileId], references: [id])
  campus  Campus  @relation(fields: [campusId], references: [id])

  @@unique([profileId, campusId])
  @@index([tenantId])
  @@index([profileId])
  @@map("user_campus_access")
}

model AuthUser {
  id           String     @id @default(uuid()) @db.Uuid
  email        String     @unique
  phone        String?    @unique
  passwordHash String?
  status       AuthStatus @default(ACTIVE)
  mfaEnabled   Boolean    @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  globalRoles  AuthUserGlobalRole[]
  memberships  TenantMembership[]
  profileLinks UserProfileLink[]
  sessions     AuthSession[]
  resetTokens  PasswordResetToken[]
  
  // New
  studentLink  StudentAuthLink?
}

model AuthUserGlobalRole {
  id        String     @id @default(uuid()) @db.Uuid
  userId    String     @db.Uuid
  role      GlobalRole
  createdAt DateTime   @default(now())

  user AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
}

model TenantMembership {
  id             String           @id @default(uuid()) @db.Uuid
  userId         String           @db.Uuid
  tenantId       String           @db.Uuid
  
  // Deprecated Role - use memberRoles instead
  role           MembershipRole?
  
  campusScope    CampusScope      @default(ALL)
  status         MembershipStatus @default(ACTIVE)
  isPrimaryAdmin Boolean          @default(false) @map("is_primary_admin")

  primaryProfileId String?   @db.Uuid
  invitedByUserId  String?   @map("invited_by_user_id") @db.Uuid
  invitedAt        DateTime? @map("invited_at") @db.Timestamptz
  activatedAt      DateTime? @map("activated_at") @db.Timestamptz
  disabledAt       DateTime? @map("disabled_at") @db.Timestamptz

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           AuthUser             @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant         Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  primaryProfile Profile?             @relation("MembershipPrimaryProfile", fields: [primaryProfileId], references: [id])
  inviteTokens   PasswordResetToken[]
  
  // New
  memberRoles    MemberRole[]

  @@unique([userId, tenantId, role]) // NOTE: This unique constraint might need relaxation in future if multiple roles allowed per user without deprecated role field
  @@index([tenantId, role])
}

model UserProfileLink {
  id           String           @id @default(uuid()) @db.Uuid
  userId       String           @db.Uuid
  profileId    String           @db.Uuid
  relationship RelationshipType @default(SELF)
  isPrimary    Boolean          @default(false)
  createdAt    DateTime         @default(now())

  user    AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([userId, profileId])
  @@index([profileId])
}

model AuthSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  refreshTokenHash String
  userAgent        String?
  ip               String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())

  user AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id            String            @id @default(uuid()) @db.Uuid
  userId        String            @db.Uuid
  tokenHash     String            @map("token_hash")
  purpose       ResetTokenPurpose
  tenantId      String?           @map("tenant_id") @db.Uuid
  membershipId  String?           @map("membership_id") @db.Uuid
  expiresAt     DateTime          @map("expires_at")
  usedAt        DateTime?         @map("used_at")
  attemptCount  Int               @default(0) @map("attempt_count")
  lastAttemptAt DateTime?         @map("last_attempt_at") @db.Timestamptz
  createdAt     DateTime          @default(now()) @map("created_at")

  user       AuthUser          @relation(fields: [userId], references: [id], onDelete: Cascade)
  membership TenantMembership? @relation(fields: [membershipId], references: [id])

  @@index([userId])
  @@index([tokenHash])
}

model Permission {
  id        String   @id @default(cuid())
  key       String   @unique // e.g. "fees.collect", "dashboard.view.finance"
  label     String
  module    String? // e.g. "dashboard", "admissions", "users"
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Deprecated
  profilePermissions ProfilePermission[]

  @@map("permissions")
}

model ProfilePermission {
  id                 String   @id @default(cuid())
  tenantId           String   @map("tenant_id") @db.Uuid
  profileId          String   @map("profile_id") @db.Uuid
  permissionId       String   @map("permission_id")
  campusId           String?  @map("campus_id") @db.Uuid // null = tenant-wide grant
  grantedByProfileId String?  @map("granted_by_profile_id") @db.Uuid
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  profile    Profile    @relation("ProfileToPermissions", fields: [profileId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  grantedBy  Profile?   @relation("GrantedByProfile", fields: [grantedByProfileId], references: [id], onDelete: SetNull)

  @@unique([tenantId, profileId, permissionId, campusId])
  @@index([tenantId, profileId])
  @@index([tenantId, profileId, campusId])
  @@index([tenantId, campusId])
  @@map("profile_permissions")
}

// Phase 3: Academic & Settings Models

model AcademicYear {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String   // "2024-2025"
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  isActive  Boolean  @default(false) @map("is_active")
  isClosed  Boolean  @default(false) @map("is_closed")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  applications Application[]
  
  @@unique([tenantId, name])
  @@map("academic_years")
}

model Program {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String   // "High School"
  type      String?  // "K12", "DEGREE"
  
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  classes   Class[]
  
  @@unique([tenantId, name])
  @@map("programs")
}

model Class {
  id        String   @id @default(uuid()) @db.Uuid
  programId String   @map("program_id") @db.Uuid
  name      String   // "Grade 10"
  
  program   Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  sections  Section[]
  
  @@unique([programId, name])
  @@map("classes")
}

model Section {
  id        String   @id @default(uuid()) @db.Uuid
  classId   String   @map("class_id") @db.Uuid
  campusId  String   @map("campus_id") @db.Uuid
  name      String   // "A"
  
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  campus    Campus   @relation(fields: [campusId], references: [id], onDelete: Cascade)
  
  @@unique([classId, campusId, name])
  @@map("sections")
}

model Template {
  id        String       @id @default(uuid()) @db.Uuid
  tenantId  String       @map("tenant_id") @db.Uuid
  type      TemplateType @map("type")
  name      String
  
  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  versions  TemplateVersion[]
  
  @@unique([tenantId, type, name])
  @@map("templates")
}

model TemplateVersion {
  id         String   @id @default(uuid()) @db.Uuid
  templateId String   @map("template_id") @db.Uuid
  version    Int
  content    Json     // The schema or fee structure
  isPublished Boolean @default(false) @map("is_published")
  createdAt  DateTime @default(now()) @map("created_at")

  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  
  @@unique([templateId, version])
  @@map("template_versions")
}

// Phase 4: Admissions Models

model Applicant {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  fullName  String   @map("full_name")
  email     String?
  phone     String
  dob       DateTime? @db.Date
  createdAt DateTime @default(now()) @map("created_at")
  
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  applications Application[]
  
  @@unique([tenantId, phone, dob])
  @@map("applicants")
}

model AdmissionOffer {
  id            String   @id @default(uuid()) @db.Uuid
  applicationId String   @unique @map("application_id") @db.Uuid
  status        String   // ISSUED, ACCEPTED, DECLINED, EXPIRED
  expiryDate    DateTime @map("expiry_date") @db.Date
  feeSnapshot   Json     @map("fee_snapshot")
  createdAt     DateTime @default(now()) @map("created_at")
  
  application   Application @relation(fields: [applicationId], references: [id])
  
  @@map("admission_offers")
}

// Phase 5: Finance Models

model FeeHead {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String
  type      String   // RECURRING, ONE_TIME
  
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  
  @@unique([tenantId, name])
  @@map("fee_heads")
}

model FeeStructure {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String
  
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  versions  FeeStructureVersion[]
  
  @@map("fee_structures")
}

model FeeStructureVersion {
  id             String   @id @default(uuid()) @db.Uuid
  feeStructureId String   @map("fee_structure_id") @db.Uuid
  version        Int
  isActive       Boolean  @default(false) @map("is_active")
  content        Json     // List of heads, amounts, due dates
  createdAt      DateTime @default(now()) @map("created_at")
  
  feeStructure   FeeStructure @relation(fields: [feeStructureId], references: [id])
  
  @@unique([feeStructureId, version])
  @@map("fee_structure_versions")
}

model StudentFeeAssignment {
  id        String   @id @default(uuid()) @db.Uuid
  studentId String   @map("student_id") @db.Uuid

  // Snapshot of what was assigned
  structureName    String @map("structure_name")
  structureVersion Int    @map("structure_version")
  snapshotContent  Json   @map("snapshot_content")

  assignedAt DateTime @default(now()) @map("assigned_at")

  student  Student   @relation(fields: [studentId], references: [id])
  invoices Invoice[]

  @@map("student_fee_assignments")
}

// Phase 6: Results Models

model PublishedResultBatch {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  campusId    String   @map("campus_id") @db.Uuid

  academicYear String  @map("academic_year")
  className    String  @map("class_name")
  sectionName  String  @map("section_name")
  examName     String  @map("exam_name")
  title        String

  fileType     PublishedResultFileType @map("file_type")
  fileKey      String  @map("file_key")
  fileName     String  @map("file_name")
  fileUrl      String? @map("file_url")

  isPublished  Boolean   @default(false) @map("is_published")
  publicToken  String    @unique @map("public_token")
  publishedAt  DateTime? @map("published_at")

  uploadedByProfileId String?  @map("uploaded_by_profile_id") @db.Uuid
  uploadedAt          DateTime @default(now()) @map("uploaded_at")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campus     Campus   @relation(fields: [campusId], references: [id], onDelete: Cascade)
  uploadedBy Profile? @relation("ResultBatchUploader", fields: [uploadedByProfileId], references: [id])

  @@index([tenantId, campusId, academicYear])
  @@index([tenantId, campusId, className, sectionName, examName])
  @@map("published_result_batches")
}

// Phase 7: Finance Transaction Models

model Invoice {
  id             String        @id @default(uuid()) @db.Uuid
  tenantId       String        @map("tenant_id") @db.Uuid
  campusId       String        @map("campus_id") @db.Uuid
  studentId      String        @map("student_id") @db.Uuid
  assignmentId   String?       @map("assignment_id") @db.Uuid
  invoiceNumber  String        @map("invoice_number")
  title          String
  description    String?
  status         InvoiceStatus @default(OPEN)
  subtotalAmount Decimal       @default(0) @map("subtotal_amount") @db.Decimal(12, 2)
  discountAmount Decimal       @default(0) @map("discount_amount") @db.Decimal(12, 2)
  totalAmount    Decimal       @default(0) @map("total_amount") @db.Decimal(12, 2)
  paidAmount     Decimal       @default(0) @map("paid_amount") @db.Decimal(12, 2)
  dueAmount      Decimal       @default(0) @map("due_amount") @db.Decimal(12, 2)
  issueDate      DateTime      @default(now()) @map("issue_date") @db.Date
  dueDate        DateTime?     @map("due_date") @db.Date
  metadata       Json?
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant     Tenant               @relation(fields: [tenantId], references: [id])
  campus     Campus               @relation(fields: [campusId], references: [id])
  student    Student              @relation(fields: [studentId], references: [id])
  assignment StudentFeeAssignment? @relation(fields: [assignmentId], references: [id])
  lines      InvoiceLine[]
  payments   Payment[]
  adjustments Adjustment[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId, campusId, status])
  @@index([tenantId, studentId])
  @@map("invoices")
}

model InvoiceLine {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  invoiceId   String   @map("invoice_id") @db.Uuid
  description String
  quantity    Int      @default(1)
  unitAmount  Decimal  @default(0) @map("unit_amount") @db.Decimal(12, 2)
  lineTotal   Decimal  @default(0) @map("line_total") @db.Decimal(12, 2)
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([tenantId, invoiceId])
  @@map("invoice_lines")
}

model Payment {
  id              String        @id @default(uuid()) @db.Uuid
  tenantId        String        @map("tenant_id") @db.Uuid
  campusId        String        @map("campus_id") @db.Uuid
  studentId       String        @map("student_id") @db.Uuid
  invoiceId       String?       @map("invoice_id") @db.Uuid
  paymentNumber   String        @map("payment_number")
  amount          Decimal       @default(0) @db.Decimal(12, 2)
  method          PaymentMethod
  status          PaymentStatus @default(COMPLETED)
  reference       String?
  notes           String?
  metadata        Json?
  collectedByUserId String?     @map("collected_by_user_id") @db.Uuid
  paidAt          DateTime      @default(now()) @map("paid_at") @db.Timestamptz
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  campus  Campus   @relation(fields: [campusId], references: [id])
  student Student  @relation(fields: [studentId], references: [id])
  invoice Invoice? @relation(fields: [invoiceId], references: [id])
  receipt Receipt?

  @@unique([tenantId, paymentNumber])
  @@index([tenantId, campusId, status])
  @@index([tenantId, studentId, paidAt])
  @@map("payments")
}

model Receipt {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  campusId      String   @map("campus_id") @db.Uuid
  studentId     String   @map("student_id") @db.Uuid
  paymentId     String   @unique @map("payment_id") @db.Uuid
  receiptNumber String   @map("receipt_number")
  amount        Decimal  @default(0) @db.Decimal(12, 2)
  issuedAt      DateTime @default(now()) @map("issued_at") @db.Timestamptz
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  campus  Campus  @relation(fields: [campusId], references: [id])
  student Student @relation(fields: [studentId], references: [id])
  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@unique([tenantId, receiptNumber])
  @@index([tenantId, campusId, issuedAt])
  @@index([tenantId, studentId])
  @@map("receipts")
}

model Adjustment {
  id                String         @id @default(uuid()) @db.Uuid
  tenantId          String         @map("tenant_id") @db.Uuid
  campusId          String         @map("campus_id") @db.Uuid
  studentId         String         @map("student_id") @db.Uuid
  invoiceId         String?        @map("invoice_id") @db.Uuid
  type              AdjustmentType
  amount            Decimal        @default(0) @db.Decimal(12, 2)
  reason            String
  createdByUserId   String?        @map("created_by_user_id") @db.Uuid
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamptz

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  campus  Campus   @relation(fields: [campusId], references: [id])
  student Student  @relation(fields: [studentId], references: [id])
  invoice Invoice? @relation(fields: [invoiceId], references: [id])

  @@index([tenantId, campusId, type])
  @@index([tenantId, studentId, createdAt])
  @@map("adjustments")
}
