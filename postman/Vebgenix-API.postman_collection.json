{
  "info": {
    "_postman_id": "vebgenix-api-collection",
    "name": "Vebgenix API",
    "description": "Complete API collection for Vebgenix Backend. Import with Vebgenix-Dev.postman_environment.json",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",     "value": "{{base_url}}" },
    { "key": "access_token", "value": "{{access_token}}" },
    { "key": "tenant_id",    "value": "{{tenant_id}}" }
  ],
  "item": [
    {
      "name": "🔐 Auth (Cognito)",
      "description": "Authentication is handled by AWS Cognito — not by the Vebgenix backend.\nSet COGNITO_DOMAIN, COGNITO_CLIENT_ID and COGNITO_REGION in the environment.\nAfter 'Get Token', the access_token variable is set automatically for all other requests.",
      "item": [
        {
          "name": "Get Token — User+Password (InitiateAuth)",
          "request": {
            "method": "POST",
            "url": "https://cognito-idp.{{cognito_region}}.amazonaws.com/",
            "header": [
              { "key": "Content-Type",  "value": "application/x-amz-json-1.1" },
              { "key": "X-Amz-Target", "value": "AWSCognitoIdentityProviderService.InitiateAuth" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"AuthFlow\": \"USER_PASSWORD_AUTH\",\n  \"ClientId\": \"{{cognito_client_id}}\",\n  \"AuthParameters\": {\n    \"USERNAME\": \"admin@example.com\",\n    \"PASSWORD\": \"YourPassword1!\"\n  }\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Got Cognito token', () => pm.expect(pm.response.code).to.equal(200));",
              "const r = pm.response.json();",
              "if (r.AuthenticationResult) {",
              "  pm.environment.set('access_token',  r.AuthenticationResult.AccessToken);",
              "  pm.environment.set('refresh_token', r.AuthenticationResult.RefreshToken);",
              "  pm.environment.set('id_token',      r.AuthenticationResult.IdToken);",
              "  console.log('Tokens saved to environment');",
              "}"
            ]}
          }]
        },
        {
          "name": "Refresh Token (InitiateAuth REFRESH_TOKEN_AUTH)",
          "request": {
            "method": "POST",
            "url": "https://cognito-idp.{{cognito_region}}.amazonaws.com/",
            "header": [
              { "key": "Content-Type",  "value": "application/x-amz-json-1.1" },
              { "key": "X-Amz-Target", "value": "AWSCognitoIdentityProviderService.InitiateAuth" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"AuthFlow\": \"REFRESH_TOKEN_AUTH\",\n  \"ClientId\": \"{{cognito_client_id}}\",\n  \"AuthParameters\": {\n    \"REFRESH_TOKEN\": \"{{refresh_token}}\"\n  }\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "const r = pm.response.json();",
              "if (r.AuthenticationResult) {",
              "  pm.environment.set('access_token', r.AuthenticationResult.AccessToken);",
              "  pm.environment.set('id_token',     r.AuthenticationResult.IdToken);",
              "}"
            ]}
          }]
        },
        {
          "name": "Revoke Token (Sign Out)",
          "request": {
            "method": "POST",
            "url": "https://cognito-idp.{{cognito_region}}.amazonaws.com/",
            "header": [
              { "key": "Content-Type",  "value": "application/x-amz-json-1.1" },
              { "key": "X-Amz-Target", "value": "AWSCognitoIdentityProviderService.RevokeToken" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"Token\": \"{{refresh_token}}\",\n  \"ClientId\": \"{{cognito_client_id}}\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Token revoked', () => pm.expect(pm.response.code).to.equal(200));",
              "pm.environment.unset('access_token');",
              "pm.environment.unset('refresh_token');",
              "pm.environment.unset('id_token');"
            ]}
          }]
        },
        {
          "name": "Me — My Profile (AppSync / EC2)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/me",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "x-tenant-id",   "value": "{{tenant_id}}" }
            ]
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.expect(pm.response.code).to.equal(200));"] } }]
        }
      ]
    },
